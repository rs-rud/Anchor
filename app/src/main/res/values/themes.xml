<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Anchor" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/anchor_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/anchor_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/anchor_on_primary_container</item>
        <item name="colorPrimaryDark">@color/anchor_primary_dark</item>

        <!-- Secondary / Accent -->
        <item name="colorSecondary">@color/anchor_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/anchor_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/anchor_on_secondary_container</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/anchor_tertiary</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/anchor_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/anchor_on_tertiary_container</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/anchor_surface</item>
        <item name="colorSurface">@color/anchor_surface</item>
        <item name="colorOnSurface">@color/anchor_on_surface</item>
        <item name="colorSurfaceVariant">@color/anchor_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/anchor_on_surface_variant</item>
        <item name="colorSurfaceContainer">@color/anchor_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/anchor_surface_container_high</item>
        <item name="colorOutline">@color/anchor_outline</item>
        <item name="colorOutlineVariant">@color/anchor_outline_variant</item>

        <!-- Error -->
        <item name="colorError">@color/anchor_error</item>
        <item name="colorOnError">@color/anchor_on_error</item>
        <item name="colorErrorContainer">@color/anchor_error_container</item>
        <item name="colorOnErrorContainer">@color/anchor_on_error_container</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Shapes -->
        <item name="shapeAppearanceCornerSmall">@style/ShapeAppearance.Anchor.Small</item>
        <item name="shapeAppearanceCornerMedium">@style/ShapeAppearance.Anchor.Medium</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.Anchor.Large</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.Anchor.ExtraLarge</item>

        <!-- Text appearance tweaks -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Anchor.DisplayLarge</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Anchor.HeadlineLarge</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Anchor.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Anchor.TitleLarge</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Anchor.LabelLarge</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Anchor.LabelSmall</item>

        <!-- Default button style -->
        <item name="materialButtonStyle">@style/Widget.Anchor.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.Anchor.BottomNav</item>
    </style>

    <style name="Theme.Anchor" parent="Base.Theme.Anchor" />

    <!-- Shape appearances -->
    <style name="ShapeAppearance.Anchor.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.Anchor.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">20dp</item>
    </style>
    <style name="ShapeAppearance.Anchor.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">28dp</item>
    </style>
    <style name="ShapeAppearance.Anchor.ExtraLarge" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSize">36dp</item>
    </style>

    <!-- Text appearances -->
    <style name="TextAppearance.Anchor.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Anchor.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Anchor.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Anchor.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:letterSpacing">-0.005</item>
    </style>

    <style name="TextAppearance.Anchor.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.Anchor.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Anchor.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.LabelLarge</item>
    </style>

    <style name="Widget.Anchor.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.Anchor.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.Anchor.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.Anchor.BottomNav.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Anchor.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorPrimaryContainer</item>
    </style>

</resources>
